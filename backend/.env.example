# InfraWatch Backend Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# Server Configuration
# =============================================================================

# Port number for the Express server (default: 3001)
PORT=3001

# Node environment: development, production, test (default: development)
NODE_ENV=development

# =============================================================================
# Solana Configuration
# =============================================================================

# Solana RPC URL for blockchain queries (default: https://api.mainnet-beta.solana.com)
SOLANA_RPC_URL=https://api.mainnet-beta.solana.com

# Helius API key for enhanced RPC access (optional but recommended)
# Get your API key at: https://helius.xyz/
HELIUS_API_KEY=your_helius_api_key_here

# Full Helius RPC URL (optional - will be constructed from HELIUS_API_KEY if not provided)
# HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=your_key

# =============================================================================
# Validators.app API Configuration
# =============================================================================

# API key for validators.app (optional - some endpoints work without it)
# Get your API key at: https://www.validators.app/
VALIDATORS_APP_API_KEY=your_validators_app_api_key

# Validators.app API base URL (default: https://www.validators.app/api/v1)
VALIDATORS_APP_BASE_URL=https://www.validators.app/api/v1

# =============================================================================
# Database Configuration
# =============================================================================

# PostgreSQL connection string (optional - used for data persistence)
# Format: postgresql://username:password@host:port/database
DATABASE_URL=postgresql://user:password@localhost:5432/infrawatch

# =============================================================================
# Cache Configuration
# =============================================================================

# Redis connection URL (default: redis://localhost:6379)
REDIS_URL=redis://localhost:6379

# =============================================================================
# Polling Intervals (in milliseconds)
# =============================================================================

# Interval for critical metric polling (default: 30000 = 30 seconds)
CRITICAL_POLL_INTERVAL=30000

# Interval for routine metric polling (default: 300000 = 5 minutes)
ROUTINE_POLL_INTERVAL=300000

# =============================================================================
# CORS Configuration
# =============================================================================

# Allowed CORS origin for frontend (default: http://localhost:5173)
CORS_ORIGIN=http://localhost:5173
